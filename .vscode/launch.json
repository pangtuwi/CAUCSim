{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run CAUCSim Server (with Auto-Reload)",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/app.js",
      "runtimeArgs": [
        "--watch"
      ],
      "console": "integratedTerminal",
      "restart": true
    }
  ]
}
